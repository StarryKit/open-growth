# Server
PORT=3001
HOST=0.0.0.0

# Supabase client used by the web app.
# Leave these empty to use the local development auth fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service credentials used only by the API.
# Never expose SUPABASE_SERVICE_ROLE_KEY to browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=content-assets

# Optional local development scope when using Supabase without a bearer token.
OPEN_GROWTH_USER_ID=

# Set to a positive number to enable periodic outbox processing.
OPEN_GROWTH_OUTBOX_INTERVAL_MS=0
