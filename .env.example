# Copy this file to `.env` for local development.
#
# Local Supabase values come from `npm run db:start` followed by
# `npm run db:status`. For Supabase preview branches or production-like testing,
# replace the local URLs and keys with that Supabase project's values.
#
# Do not add platform OAuth app credentials such as X or Reddit client secrets
# here. Those are stored through the Open Growth admin OAuth app settings backed
# by Supabase, not through environment variables.

# Fastify API port. `apps/api/src/index.ts` defaults to 3001 when this is unset.
# Change this only when another local service already uses port 3001 or when the
# deployment platform requires a specific port.
PORT=3001

# Fastify API bind host. `0.0.0.0` makes the API reachable from other local
# containers and dev proxies; use `127.0.0.1` if you intentionally want local
# loopback only.
HOST=0.0.0.0

# Browser-safe Supabase project URL used by the Vite web app for Supabase Auth.
# Vite exposes variables prefixed with `VITE_` to browser code, so this must be
# the public Supabase API URL, not a secret.
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Browser-safe Supabase anon key used by the Vite web app for login/session
# flows. Copy the `anon key` from `npm run db:status` for the local Supabase
# stack, or use the anon key for the selected non-production Supabase project.
VITE_SUPABASE_ANON_KEY=<copy anon key from supabase status>

# Server-side Supabase project URL used by the API and database package for
# authenticated API requests, domain storage, and media storage. This usually
# matches `VITE_SUPABASE_URL`, but it is intentionally not exposed to Vite.
SUPABASE_URL=http://127.0.0.1:54321

# Server-side Supabase service role key. The API uses this to validate Supabase
# Auth bearer tokens, call database RPCs, and write Storage objects. Never expose
# this value to browser code, logs, or frontend deployment variables.
SUPABASE_SERVICE_ROLE_KEY=<copy service_role key from supabase status>

# Supabase Storage bucket for uploaded content assets. The API falls back to
# `content-assets` when unset; keep this aligned with the bucket created by
# migrations or by the target Supabase project.
SUPABASE_STORAGE_BUCKET=content-assets

# Optional local Supabase Auth Google provider client ID. This is read only by
# the Supabase CLI config at `packages/db/supabase/config.toml` when starting the
# local Supabase stack through the repo `npm run db:*` scripts. Hosted Supabase
# projects should configure Google Auth in the Supabase Dashboard instead.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=

# Optional local Supabase Auth Google provider client secret. Keep this out of
# git. After changing it, restart the local Supabase stack so the CLI reloads
# `packages/db/supabase/config.toml`.
SUPABASE_AUTH_GOOGLE_SECRET=

# Default Supabase Auth user ID for API-side development paths that need a user
# scope when no request context is available, such as scripts or service-role
# database helpers. Use a real local seeded user UUID when testing scoped data.
OPEN_GROWTH_USER_ID=00000000-0000-0000-0000-000000000001

# Comma-separated Supabase Auth user IDs allowed to access admin-only API
# surfaces, including Collector identity management and OAuth app/deployment
# settings. Leave empty in environments where no admin UI access is intended.
OPEN_GROWTH_ADMIN_USER_IDS=00000000-0000-0000-0000-000000000001

# Periodic outbox worker interval in milliseconds. `0` disables the background
# polling worker, which is the local-development default. Set a positive value
# only when this API process should actively process outbox events.
OPEN_GROWTH_OUTBOX_INTERVAL_MS=0
