# Copy this file to `.env`.
# For local development, run `supabase start`, then copy the anon and
# service_role keys from `supabase status`.
# For remote branch or production testing, replace the local URLs and keys with
# that Supabase project's values.

PORT=3001
HOST=0.0.0.0

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<copy anon key from supabase status>

# Never expose SUPABASE_SERVICE_ROLE_KEY to browser code.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=<copy service_role key from supabase status>
SUPABASE_STORAGE_BUCKET=content-assets

OPEN_GROWTH_USER_ID=00000000-0000-0000-0000-000000000001

OPEN_GROWTH_OUTBOX_INTERVAL_MS=0
